# Database
DATABASE_URL=postgresql+asyncpg://flora:flora@localhost:5432/flora

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Groq (free cloud, fast)
GROQ_API_KEY=

# Together.ai (cheap fallback)
TOGETHER_API_KEY=

# OpenAI (optional, comparison)
OPENAI_API_KEY=

# Active LLM provider: ollama | groq | together | openai
LLM_PROVIDER=ollama

# AWS (optional, for S3 artifact storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=flora-assets

# Replicate (optional, for SDXL lock images)
REPLICATE_API_TOKEN=

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# App
LOG_LEVEL=INFO
ENVIRONMENT=development
